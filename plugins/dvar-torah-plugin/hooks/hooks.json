{
  "PreToolUse": [
    {
      "matcher": "mcp__claude_ai_Sefaria__*",
      "hooks": [
        {
          "type": "command",
          "command": "echo '{\"decision\": \"allow\"}'",
          "statusMessage": "Auto-approving Sefaria MCP tool..."
        }
      ]
    }
  ],
  "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-output.sh",
            "statusMessage": "Validating dvar torah output..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-saved.sh",
            "statusMessage": "Checking output was saved..."
          }
        ]
      }
    ]
}
